# ============================================================================
# Portfolio Backend - Environment Variables
# Copy this file to `.env` and fill in your real values.
# NEVER commit the real `.env` file (it is ignored by .gitignore).
# ============================================================================

# --- MongoDB Atlas ---
# Purpose: Connection string for your MongoDB Atlas cluster.
# Example: mongodb+srv://user:pass@cluster0.abcde.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
DB_NAME=portfolio

# --- Redis (optional but recommended) ---
# Purpose: Fast public cache after admin Sync. Leave empty to use MongoDB only.
# Local:   redis://localhost:6379/0
# Upstash: rediss://default:<TOKEN>@<HOST>.upstash.io:6379
REDIS_URL=

# --- Admin authentication (JWT) ---
# Purpose: Credentials for the single admin (you) to log in and post projects.
ADMIN_EMAIL=aryannayak1509@gmail.com
ADMIN_PASSWORD=change-this-strong-password
# Purpose: Secret used to sign JWT access tokens. Generate a random string.
# Example (python): python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- GitHub ---
# Purpose: GitHub username whose PUBLIC repos are imported into the Projects section.
GITHUB_USERNAME=AryanJNayak
# Purpose: (Optional) Personal access token to raise the GitHub API rate limit.
# Leave empty to use unauthenticated requests (60/hour is usually enough).
GITHUB_TOKEN=

# --- LeetCode ---
# Purpose: LeetCode username used to fetch rating / contest / KPI stats.
LEETCODE_USERNAME=Jsjsn73

# --- CORS ---
# Purpose: Comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- SMTP (contact form → email you) ---
# Purpose: When someone submits the Contact form, the backend emails you
#          their name, email, subject, and message via SMTP.
#
# Gmail example (recommended):
#   1. Enable 2-Step Verification on your Google account
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Use that 16-char password as SMTP_PASSWORD (not your normal password)
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=aryannayak1509@gmail.com
SMTP_PASSWORD=your-16-char-app-password
# Optional — defaults shown:
SMTP_FROM=aryannayak1509@gmail.com
SMTP_TO=aryannayak1509@gmail.com
SMTP_USE_TLS=true
SMTP_USE_SSL=false
